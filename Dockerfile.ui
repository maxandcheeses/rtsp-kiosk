# Stage 1: install npm deps and bundle mqtt.min.js into www/
FROM node:20-alpine AS builder

WORKDIR /build
COPY package.json ./
RUN npm install
COPY www/ ./www/
RUN npm run build

# Stage 2: serve the UI — no CDN required, fully offline capable
FROM nginx:alpine

# Install inotify-tools for file watching (fallback: polling in watcher script)
RUN apk add --no-cache tini

COPY --from=builder /build/www/ /usr/share/nginx/html/
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY scripts/reload-watcher.sh /reload-watcher.sh
RUN chmod +x /reload-watcher.sh

# entrypoint is overridden in docker-compose for envsubst