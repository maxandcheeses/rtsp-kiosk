# ═══════════════════════════════════════════════════════
# RTSP Kiosk — environment variables
# Copy this file to .env and update values for your setup.
# ═══════════════════════════════════════════════════════

# IP address of this host — used for WebRTC ICE and STUN
HOST_IP=<this-container-ip>

# STUN server listening port (default: 3478)
STUN_PORT=3478